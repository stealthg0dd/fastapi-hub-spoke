# ── Database ──────────────────────────────────────────────────────────────────
# Inside Docker Compose (service name as host)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/hubdb
# Local / direct connection (for running outside Docker)
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/hubdb

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-in-production

# ── Hub ───────────────────────────────────────────────────────────────────────
HUB_NAME=Hub
HUB_URL=http://hub:8000

# ── Spoke (set per spoke service) ─────────────────────────────────────────────
SPOKE_NAME=spoke-template

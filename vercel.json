{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "backend/shared_services/main.py"
    },
    {
      "source": "/portal/(.*)",
      "destination": "/portal/index.html"
    },
    {
      "source": "/portal",
      "destination": "/portal/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "backend/shared_services/main.py"
    },
    {
      "source": "/portal/(.*)",
      "destination": "/frontend-portal/dist/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/frontend-landing/dist/index.html"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,POST,PUT,DELETE,OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type,X-Venture-ID,X-API-Key,Authorization" }
      ]
    }
  ]
}
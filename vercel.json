{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "backend/shared_services/main.py"
    },
    {
      "source": "/portal/(.*)",
      "destination": "/portal/index.html"
    },
    {
      "source": "/((?!api|portal).*)",
      "destination": "/index.html"
    }
  ]
}